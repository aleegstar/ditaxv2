# Example environment file for Ditax
# Copy to .env locally. NEVER commit real secrets.
#
# These VITE_* values are PUBLISHABLE (anon) Supabase keys and are safe to
# expose in the frontend bundle — they are protected by Row Level Security.
# See SECURITY.md for details.

VITE_SUPABASE_PROJECT_ID="your-project-ref"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-anon-key"

# Server-side secrets (Stripe, OpenAI, Resend, Vertex AI, etc.) are NEVER
# stored in this file. They live in Supabase Edge Function Secrets and are
# accessed via Deno.env.get() inside supabase/functions/*.
